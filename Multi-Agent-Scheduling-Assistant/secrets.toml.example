# Copy this file to .streamlit/secrets.toml for LOCAL development so it
# behaves the same way Streamlit Community Cloud's Settings -> Secrets does.
#
# On Streamlit Community Cloud itself, do NOT upload this file - instead
# paste the same TOML content into the app's Settings -> Secrets box in the
# dashboard. Cloud secrets are stored outside the repo and are never
# committed to git.
#
# .streamlit/secrets.toml is already listed in .gitignore so a real,
# filled-in copy of it won't accidentally get committed if you use it
# locally.

GOOGLE_API_KEY = secrets.GOOGLE_API_KEY

# Optional - if unset, booking/driver notifications are simulated (printed
# to the app logs) instead of actually POSTed anywhere.
# WEBHOOK_URL = secrets.WEBHOOK_URL
