# Copy this file to .streamlit/secrets.toml for LOCAL development so it
# behaves the same way Streamlit Community Cloud's Settings -> Secrets does.
#
# On Streamlit Community Cloud itself, do NOT upload a filled-in copy of
# this file. Instead open the app's Settings -> Secrets box in the
# dashboard and paste the same two lines (with real values) there. Cloud
# secrets are stored outside the repo and are never committed to git.
#
# NOTE on GitHub repo secrets: GitHub Actions "repo secrets" and Streamlit
# Community Cloud "app secrets" are two separate, unconnected systems.
# Storing GOOGLE_API_KEY / WEBHOOK_URL as GitHub repo secrets makes them
# available to GitHub Actions workflows only - Streamlit Cloud has no way
# to read them automatically. To make this app work, copy the *same*
# values into Streamlit Cloud's own Settings -> Secrets box for this app.
#
# .streamlit/secrets.toml (the real, filled-in file - not this .example
# file) is listed in .gitignore so it never gets committed by accident.

GOOGLE_API_KEY = "your-google-gemini-api-key-here"

# Optional - if unset, booking/driver notifications are simulated (printed
# to the app logs) instead of actually POSTed anywhere.
WEBHOOK_URL = "https://your-pipedream-endpoint.m.pipedream.net"
